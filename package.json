{
  "name": "financeos-india",
  "version": "1.0.0",
  "private": true,
  "description": "Premium Local-First Personal & Business Finance Suite for India",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:desktop\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:web": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build:packages": "npm run build --workspaces --if-present",
    "build:libs": "npm run build --workspace=packages/shared --workspace=packages/auth --workspace=packages/database --workspace=packages/ui",
    "package": "npm run build --workspaces --if-present && node -e \"require('fs').cpSync('apps/web/dist', 'apps/desktop/web-dist', {recursive: true})\" && npm run package --workspace=apps/desktop",
    "install:all": "npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "electron": "^43.1.1",
    "sharp": "^0.35.3"
  }
}
